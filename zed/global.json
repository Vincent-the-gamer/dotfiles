{
  "experimental.theme_overrides": {
    "background.appearance": "blurred",
    "renamed.background": "#FFFFFF30",
    "search.match_background": "#FFFFFF30",
    "ghost_element.background": "#00000030",
    "ghost_element.hover": "#000000CC",
    "background": "#000000DD",
    "editor.background": "#00000000",
    "editor.gutter.background": "#00000000",
    "title_bar.background": "#000000EE",
    "toolbar.background": "#00000000",
    "terminal.background": "#00000000",
    "status_bar.background": "#000000EE",
    "tab.active_background": "#000000",
    "tab.inactive_background": "#00000000",
    "tab_bar.background": "#00000000",
    "panel.background": "#00000000",
    "border": "#00000000",
    "border.variant": "#00000000",
    "scrollbar.track.border": "#00000000",
    "scrollbar.track.background": "#00000000",
    "scrollbar.thumb.background": "#FFFFFF20",
    "scrollbar.thumb.border": "#FFFFFF90",
    "editor.active_line.background": "#00000000",
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "calls": {
    "mute_on_join": true
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "ensure_final_newline_on_save": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "tabs": {
    "git_status": true
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "icon_theme": "Catppuccin Mocha",
  "format_on_save": "on",
  "disable_ai": false,
  "autosave": "on_focus_change",
  "buffer_font_family": "Input",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "Vitesse Refined Light Soft",
    "dark": "Vitesse Refined Dark"
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": []
    },
    "Vue.js": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Markdown": {
      "format_on_save": "off",
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "eslint": {
      "settings": {
        "rulesCustomizations": [
          { "rule": "style/*", "severity": "off", "fixable": true },
          { "rule": "perfectionist/*", "severity": "off", "fixable": true },
          { "rule": "format/*", "severity": "off", "fixable": true },
          { "rule": "*-indent", "severity": "off", "fixable": true },
          { "rule": "*-spacing", "severity": "off", "fixable": true },
          { "rule": "*-spaces", "severity": "off", "fixable": true },
          { "rule": "*-order", "severity": "off", "fixable": true },
          { "rule": "*-dangle", "severity": "off", "fixable": true },
          { "rule": "*-newline", "severity": "off", "fixable": true },
          { "rule": "*quotes", "severity": "off", "fixable": true },
          { "rule": "*semi", "severity": "off", "fixable": true },
          { "rule": "no-console", "severity": "off", "fixable": true }
        ]
      }
    }
  }
}
